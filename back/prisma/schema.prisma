generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex", "fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model amenity {
  id           String         @id
  name         String         @unique(map: "Amenity_name_key")
  icon         String?
  hotelamenity hotelamenity[]
}

model attraction {
  id                    String                  @id
  name                  String
  slug                  String                  @unique(map: "Attraction_slug_key")
  description           String                  @db.Text
  address               String
  latitude              Float
  longitude             Float
  entryType             String                  @default("free")
  price                 Float?
  crowdLevel            String                  @default("low")
  isFeatured            Boolean                 @default(false)
  status                String                  @default("active")
  vendorId              String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  city                  String?
  audioUrl              String?
  searchKeywords        String?                 @db.Text
  virtualTourUrl        String?
  category              attraction_category     @default(Muzey)
  googleMapsUrl         String?
  user                  user?                   @relation(fields: [vendorId], references: [id], map: "Attraction_vendorId_fkey")
  attractionfavorite    attractionfavorite[]
  attractionhourlystat  attractionhourlystat[]
  attractionimage       attractionimage[]
  attractionreview      attractionreview[]
  attractionstat        attractionstat?
  attractionworkinghour attractionworkinghour[]
  booking               booking[]
  hotelpoi              hotelpoi[]
  review                review[]

  @@index([category, status, isFeatured], map: "Attraction_category_status_isFeatured_idx")
  @@index([latitude, longitude], map: "Attraction_latitude_longitude_idx")
  @@index([vendorId], map: "Attraction_vendorId_fkey")
  @@fulltext([name, description, searchKeywords], map: "Attraction_name_description_searchKeywords_idx")
}

model attractionfavorite {
  id           String     @id
  userId       String
  attractionId String
  createdAt    DateTime   @default(now())
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionFavorite_attractionId_fkey")
  user         user       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "AttractionFavorite_userId_fkey")

  @@unique([userId, attractionId], map: "AttractionFavorite_userId_attractionId_key")
  @@index([attractionId], map: "AttractionFavorite_attractionId_fkey")
}

model attractionhourlystat {
  attractionId String
  date         DateTime   @db.Date
  hour         Int
  count        Int        @default(0)
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionHourlyStat_attractionId_fkey")

  @@id([attractionId, date, hour])
}

model attractionimage {
  id           String     @id
  attractionId String
  url          String
  type         String     @default("image")
  isCover      Boolean    @default(false)
  order        Int        @default(0)
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionImage_attractionId_fkey")

  @@index([attractionId], map: "AttractionImage_attractionId_fkey")
}

model attractionreview {
  id           String     @id
  userId       String
  attractionId String
  rating       Int
  comment      String?    @db.Text
  status       String     @default("approved")
  createdAt    DateTime   @default(now())
  images       String?    @db.LongText
  vendorReply  String?    @db.Text
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionReview_attractionId_fkey")
  user         user       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "AttractionReview_userId_fkey")

  @@unique([userId, attractionId], map: "AttractionReview_userId_attractionId_key")
  @@index([attractionId], map: "AttractionReview_attractionId_fkey")
}

model attractionstat {
  attractionId    String     @id
  averageRating   Float      @default(0)
  viewCount       Int        @default(0)
  favoriteCount   Int        @default(0)
  popularityScore Float      @default(0)
  attraction      attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionStat_attractionId_fkey")
}

model attractionworkinghour {
  id           String     @id
  attractionId String
  dayOfWeek    Int
  openTime     String?
  closeTime    String?
  isClosed     Boolean    @default(false)
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "AttractionWorkingHour_attractionId_fkey")

  @@unique([attractionId, dayOfWeek], map: "AttractionWorkingHour_attractionId_dayOfWeek_key")
}

model blacklist {
  id        String   @id
  type      String
  value     String   @unique(map: "Blacklist_value_key")
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([value], map: "Blacklist_value_idx")
}

model booking {
  id                 String               @id
  bookingNumber      String               @unique(map: "Booking_bookingNumber_key")
  bookingType        String
  entityId           String
  userId             String
  vendorId           String
  status             String               @default("draft")
  paymentStatus      String               @default("initiated")
  totalPrice         Float
  currency           String               @default("AZN")
  paymentMethod      String?
  paymentId          String?
  specialRequests    String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  hotelId            String?
  tourId             String?
  eventId            String?
  attractionId       String?
  vehicleId          String?
  attraction         attraction?          @relation(fields: [attractionId], references: [id], map: "Booking_attractionId_fkey")
  event              event?               @relation(fields: [eventId], references: [id], map: "Booking_eventId_fkey")
  hotel              hotel?               @relation(fields: [hotelId], references: [id], map: "Booking_hotelId_fkey")
  tour               tour?                @relation(fields: [tourId], references: [id], map: "Booking_tourId_fkey")
  user               user                 @relation(fields: [userId], references: [id], map: "Booking_userId_fkey")
  vehicle            vehicle?             @relation(fields: [vehicleId], references: [id], map: "Booking_vehicleId_fkey")
  bookingauditlog    bookingauditlog[]
  bookingitem        bookingitem[]
  guest              guest[]
  paymenttransaction paymenttransaction[]

  @@index([attractionId], map: "Booking_attractionId_fkey")
  @@index([bookingType, entityId], map: "Booking_bookingType_entityId_idx")
  @@index([eventId], map: "Booking_eventId_fkey")
  @@index([hotelId], map: "Booking_hotelId_fkey")
  @@index([tourId], map: "Booking_tourId_fkey")
  @@index([userId], map: "Booking_userId_idx")
  @@index([vehicleId], map: "Booking_vehicleId_fkey")
  @@index([vendorId], map: "Booking_vendorId_idx")
}

model bookingauditlog {
  id        String   @id
  bookingId String
  action    String
  meta      String?  @db.LongText
  createdAt DateTime @default(now())
  booking   booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade, map: "BookingAuditLog_bookingId_fkey")

  @@index([bookingId], map: "BookingAuditLog_bookingId_fkey")
}

model bookingitem {
  id               String    @id
  bookingId        String
  roomTypeId       String?
  ratePlanId       String?
  checkIn          DateTime?
  checkOut         DateTime?
  adults           Int       @default(1)
  children         Int       @default(0)
  price            Float
  nightlyBreakdown String?   @db.LongText
  booking          booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade, map: "BookingItem_bookingId_fkey")

  @@index([bookingId], map: "BookingItem_bookingId_fkey")
}

model cancellationpolicy {
  id                         String     @id
  name                       String
  freeCancellationUntilHours Int?
  penaltyType                String
  penaltyValue               Float
  rateplan                   rateplan[]
}

model cargovehicle {
  id                  String                 @id
  vendorId            String
  brand               String
  model               String
  year                Int
  licensePlate        String
  cargoType           cargovehicle_cargoType @default(Box)
  maxWeightKg         Float
  maxVolumeM3         Float
  isRefrigerated      Boolean                @default(false)
  temperatureRangeMin Float?
  temperatureRangeMax Float?
  insuranceValidUntil DateTime?
  status              cargovehicle_status    @default(Available)
  currentLoadWeight   Float                  @default(0)
  currentLoadVolume   Float                  @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime
  user                user                   @relation(fields: [vendorId], references: [id], map: "CargoVehicle_vendorId_fkey")
  driverprofile       driverprofile?
  shipment            shipment[]

  @@index([vendorId], map: "CargoVehicle_vendorId_idx")
}

model cuisine {
  id                String              @id
  name              String              @unique(map: "Cuisine_name_key")
  restaurantcuisine restaurantcuisine[]
}

model dailypricing {
  id                String   @id
  date              DateTime @db.Date
  basePrice         Float
  currency          String   @default("AZN")
  minStay           Int      @default(1)
  maxStay           Int?
  closedToArrival   Boolean  @default(false)
  closedToDeparture Boolean  @default(false)
  roomTypeId        String
  isStopped         Boolean  @default(false)
  roomtype          roomtype @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, map: "DailyPricing_roomTypeId_fkey")

  @@unique([roomTypeId, date], map: "DailyPricing_roomTypeId_date_key")
}

model drivercapability {
  id                  String                      @id
  driverProfileId     String
  capability          drivercapability_capability
  expiryDate          DateTime?
  certificationNumber String?
  issuingAuthority    String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime
  driverprofile       driverprofile               @relation(fields: [driverProfileId], references: [id], onDelete: Cascade, map: "DriverCapability_driverProfileId_fkey")

  @@unique([driverProfileId, capability], map: "DriverCapability_driverProfileId_capability_key")
}

model driverprofile {
  id                                   String               @id
  userId                               String               @unique(map: "DriverProfile_userId_key")
  managedById                          String?
  status                               driverprofile_status @default(Pending)
  firstName                            String
  lastName                             String
  phone                                String
  licenseNumber                        String?
  licenseImages                        String?              @db.LongText
  idCardImages                         String?              @db.LongText
  currentLocation                      String?              @db.LongText
  rating                               Float                @default(5)
  totalRides                           Int                  @default(0)
  currentVehicleId                     String?              @unique(map: "DriverProfile_currentVehicleId_key")
  currentCargoVehicleId                String?              @unique(map: "DriverProfile_currentCargoVehicleId_key")
  drivercapability                     drivercapability[]
  cargovehicle                         cargovehicle?        @relation(fields: [currentCargoVehicleId], references: [id], map: "DriverProfile_currentCargoVehicleId_fkey")
  vehicle                              vehicle?             @relation(fields: [currentVehicleId], references: [id], map: "DriverProfile_currentVehicleId_fkey")
  user_driverprofile_managedByIdTouser user?                @relation("driverprofile_managedByIdTouser", fields: [managedById], references: [id], map: "DriverProfile_managedById_fkey")
  user_driverprofile_userIdTouser      user                 @relation("driverprofile_userIdTouser", fields: [userId], references: [id], onDelete: Cascade, map: "DriverProfile_userId_fkey")
  ride                                 ride[]
  shipment                             shipment[]

  @@index([managedById], map: "DriverProfile_managedById_fkey")
}

model event {
  id          String       @id
  vendorId    String
  title       String
  description String       @db.Text
  category    String
  city        String
  location    String
  latitude    Float?
  longitude   Float?
  startDate   DateTime
  endDate     DateTime
  capacity    Int          @default(0)
  ticketPrice Float        @default(0)
  soldCount   Int          @default(0)
  status      event_status @default(active)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  booking     booking[]
  user        user         @relation(fields: [vendorId], references: [id], map: "Event_vendorId_fkey")
  review      review[]
  ticket      ticket[]

  @@index([vendorId], map: "Event_vendorId_fkey")
}

model guest {
  id          String  @id
  bookingId   String
  firstName   String
  lastName    String
  nationality String?
  phone       String?
  email       String?
  booking     booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, map: "Guest_bookingId_fkey")

  @@index([bookingId], map: "Guest_bookingId_fkey")
}

model hotel {
  id                  String               @id
  name                String
  slug                String?              @unique(map: "Hotel_slug_key")
  description         String               @db.Text
  starRating          Int?
  propertyType        String               @default("hotel")
  checkInTime         String?
  checkOutTime        String?
  address             String
  latitude            Float?
  longitude           Float?
  phone               String?
  email               String?
  policies            String?              @db.LongText
  status              String               @default("active")
  isFeatured          Boolean              @default(false)
  featuredUntil       DateTime?
  featuredPriority    Int                  @default(0)
  ownerId             String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  city                String?
  cancellationPolicy  String?              @db.Text
  childPolicy         String?              @db.Text
  petPolicy           String?              @db.Text
  googleMapsUrl       String?              @db.Text
  booking             booking[]
  user                user                 @relation(fields: [ownerId], references: [id], map: "Hotel_ownerId_fkey")
  hotelamenity        hotelamenity[]
  hotelcalendarnote   hotelcalendarnote[]
  hoteldailystat      hoteldailystat[]
  hotelfavorite       hotelfavorite[]
  hotelimage          hotelimage[]
  hotelpoi            hotelpoi[]
  hotelsearchsnapshot hotelsearchsnapshot?
  pricingrule         pricingrule[]
  promotion           promotion[]
  review              review[]
  roomtype            roomtype[]

  @@index([latitude, longitude], map: "Hotel_latitude_longitude_idx")
  @@index([ownerId], map: "Hotel_ownerId_idx")
}

model hotelamenity {
  id        String  @id
  hotelId   String
  amenityId String
  amenity   amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade, map: "HotelAmenity_amenityId_fkey")
  hotel     hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelAmenity_hotelId_fkey")

  @@unique([hotelId, amenityId], map: "HotelAmenity_hotelId_amenityId_key")
  @@index([amenityId], map: "HotelAmenity_amenityId_fkey")
}

model hotelcalendarnote {
  id        String   @id
  hotelId   String
  date      DateTime @db.Date
  note      String   @db.Text
  type      String   @default("info")
  createdAt DateTime @default(now())
  updatedAt DateTime
  hotel     hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelCalendarNote_hotelId_fkey")

  @@unique([hotelId, date], map: "HotelCalendarNote_hotelId_date_key")
}

model hoteldailystat {
  id               String   @id
  hotelId          String
  date             DateTime @db.Date
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  totalBookings    Int      @default(0)
  totalRevenue     Float    @default(0)
  conversionRate   Float    @default(0)
  cancellationRate Float    @default(0)
  hotel            hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelDailyStat_hotelId_fkey")

  @@unique([hotelId, date], map: "HotelDailyStat_hotelId_date_key")
}

model hotelfavorite {
  id        String   @id
  userId    String
  hotelId   String
  createdAt DateTime @default(now())
  hotel     hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelFavorite_hotelId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "HotelFavorite_userId_fkey")

  @@unique([userId, hotelId], map: "HotelFavorite_userId_hotelId_key")
  @@index([hotelId], map: "HotelFavorite_hotelId_fkey")
}

model hotelimage {
  id      String @id
  hotelId String
  url     String
  order   Int    @default(0)
  hotel   hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelImage_hotelId_fkey")

  @@index([hotelId], map: "HotelImage_hotelId_fkey")
}

model hotelpoi {
  id           String     @id
  hotelId      String
  attractionId String
  distance     Float?
  description  String?    @db.Text
  order        Int        @default(0)
  attraction   attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "HotelPOI_attractionId_fkey")
  hotel        hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelPOI_hotelId_fkey")

  @@unique([hotelId, attractionId], map: "HotelPOI_hotelId_attractionId_key")
  @@index([attractionId], map: "HotelPOI_attractionId_fkey")
}

model hotelsearchsnapshot {
  hotelId        String   @id
  minPrice       Float
  reviewScore    Float
  availableToday Boolean
  popularity     Int
  updatedAt      DateTime
  hotel          hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "HotelSearchSnapshot_hotelId_fkey")
}

model inventorylock {
  id         String   @id
  roomTypeId String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  userId     String   @default("anonymous")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  roomtype   roomtype @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, map: "InventoryLock_roomTypeId_fkey")

  @@index([expiresAt], map: "InventoryLock_expiresAt_idx")
  @@index([roomTypeId, startDate, endDate], map: "InventoryLock_roomTypeId_startDate_endDate_idx")
}

model investorprofile {
  id              String  @id
  investmentFocus String? @db.LongText
  budgetRange     String? @db.LongText
  companyName     String?
  userId          String  @unique(map: "InvestorProfile_userId_key")
  user            user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "InvestorProfile_userId_fkey")
}

model location {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(255)
  lat           Float
  lng           Float
  type          String
  popularity    Int      @default(0)
  createdAt     DateTime @default(now())
  address       String?  @db.VarChar(255)
  googleMapsUrl String?  @db.Text
  vendorId      String?
  user          user?    @relation(fields: [vendorId], references: [id], map: "Location_vendorId_fkey")

  @@index([vendorId], map: "Location_vendorId_fkey")
  @@fulltext([name], map: "Location_name_idx")
}

model menucategory {
  id           String     @id
  name         String
  description  String?
  restaurantId String
  sortOrder    Int        @default(0)
  restaurant   restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade, map: "MenuCategory_restaurantId_fkey")
  menuitem     menuitem[]

  @@index([restaurantId], map: "MenuCategory_restaurantId_fkey")
}

model menuitem {
  id             String           @id
  categoryId     String
  name           String
  description    String?
  price          Float
  imageUrl       String?
  isAvailable    Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  menucategory   menucategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "MenuItem_categoryId_fkey")
  menuitemoption menuitemoption[]

  @@index([categoryId], map: "MenuItem_categoryId_fkey")
}

model menuitemoption {
  id         String   @id
  itemId     String
  name       String
  choices    String   @db.LongText
  isRequired Boolean  @default(false)
  maxSelect  Int      @default(1)
  menuitem   menuitem @relation(fields: [itemId], references: [id], onDelete: Cascade, map: "MenuItemOption_itemId_fkey")

  @@index([itemId], map: "MenuItemOption_itemId_fkey")
}

model paymenttransaction {
  id              String   @id
  bookingId       String
  provider        String
  providerTransId String?  @unique(map: "PaymentTransaction_providerTransId_key")
  amount          Float
  currency        String   @default("AZN")
  status          String   @default("pending")
  paymentUrl      String?  @db.Text
  callbackUrl     String?  @db.Text
  errorMessage    String?  @db.Text
  rawResponse     String?  @db.LongText
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  booking         booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade, map: "PaymentTransaction_bookingId_fkey")

  @@index([bookingId], map: "PaymentTransaction_bookingId_idx")
}

model pricingrule {
  id                 String    @id
  hotelId            String
  roomTypeId         String?
  name               String
  description        String?   @db.Text
  type               String
  adjustment         String
  value              Float
  startDate          DateTime? @db.Date
  endDate            DateTime? @db.Date
  daysOfWeek         String?
  priority           Int       @default(0)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  occupancyThreshold Float?
  hotel              hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "PricingRule_hotelId_fkey")
  roomtype           roomtype? @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, map: "PricingRule_roomTypeId_fkey")

  @@index([hotelId, roomTypeId], map: "PricingRule_hotelId_roomTypeId_idx")
  @@index([roomTypeId], map: "PricingRule_roomTypeId_fkey")
}

model promocode {
  id                String     @id
  restaurantId      String
  code              String     @unique(map: "PromoCode_code_key")
  discountType      String
  discountValue     Float
  minOrderValue     Float?
  validFrom         DateTime
  validUntil        DateTime
  usageLimit        Int?
  usedCount         Int        @default(0)
  isStackable       Boolean    @default(false)
  maxDiscountAmount Float?
  isActive          Boolean    @default(true)
  restaurant        restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade, map: "PromoCode_restaurantId_fkey")

  @@index([restaurantId], map: "PromoCode_restaurantId_fkey")
}

model promotion {
  id              String   @id
  name            String
  discountType    String
  discountValue   Float
  validFrom       DateTime
  validTo         DateTime
  minStay         Int?
  mobileOnly      Boolean  @default(false)
  geniusOnly      Boolean  @default(false)
  hotelId         String?
  code            String   @unique(map: "Promotion_code_key")
  isActive        Boolean  @default(true)
  maxUses         Int      @default(0)
  minBookingValue Float    @default(0)
  usedCount       Int      @default(0)
  hotel           hotel?   @relation(fields: [hotelId], references: [id], onDelete: Cascade, map: "Promotion_hotelId_fkey")

  @@index([hotelId], map: "Promotion_hotelId_fkey")
}

model rateplan {
  id                   String              @id
  name                 String
  mealPlan             String              @default("RO")
  isRefundable         Boolean             @default(true)
  prepaymentRequired   Boolean             @default(false)
  active               Boolean             @default(true)
  roomTypeId           String
  cancellationPolicyId String?
  cancellationpolicy   cancellationpolicy? @relation(fields: [cancellationPolicyId], references: [id], map: "RatePlan_cancellationPolicyId_fkey")
  roomtype             roomtype            @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, map: "RatePlan_roomTypeId_fkey")

  @@index([cancellationPolicyId], map: "RatePlan_cancellationPolicyId_fkey")
  @@index([roomTypeId], map: "RatePlan_roomTypeId_fkey")
}

model residentprofile {
  id            String  @id
  permitNumber  String?
  localAddress  String?
  familyMembers String? @db.LongText
  userId        String  @unique(map: "ResidentProfile_userId_key")
  user          user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ResidentProfile_userId_fkey")
}

model restaurant {
  id                  String                @id
  name                String
  slug                String                @unique(map: "Restaurant_slug_key")
  description         String?               @db.LongText
  priceRange          Int
  address             String
  latitude            Float
  longitude           Float
  workingHours        String?               @db.LongText
  isFeatured          Boolean               @default(false)
  featuredUntil       DateTime?
  featuredPriority    Int                   @default(0)
  status              String                @default("active")
  rating              Float                 @default(0)
  reviewCount         Int                   @default(0)
  vendorId            String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
