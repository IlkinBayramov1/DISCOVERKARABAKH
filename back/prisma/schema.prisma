  @@unique([userId, attractionId], map: "Review_userId_attractionId_key")
  @@unique([userId, eventId], map: "Review_userId_eventId_key")
  @@unique([userId, hotelId], map: "Review_userId_hotelId_key")
  @@unique([userId, tourId], map: "Review_userId_tourId_key")
  @@index([attractionId], map: "Review_attractionId_fkey")
  @@index([eventId], map: "Review_eventId_fkey")
  @@index([hotelId], map: "Review_hotelId_fkey")
  @@index([restaurantId, userId], map: "Review_restaurantId_userId_idx")
  @@index([tourId], map: "Review_tourId_fkey")
}

model reviewreport {
