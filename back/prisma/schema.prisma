}

model review {
  id               String      @id
  rating           Float
  cleanlinessScore Float?
  locationScore    Float?
  staffScore       Float?
  comment          String?     @db.Text
  userId           String
  hotelId          String?
  tourId           String?
  eventId          String?
  restaurantId     String?
  status           String      @default("pending")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime
  attractionId     String?
  vendorReply      String?     @db.Text
  attraction       attraction? @relation(fields: [attractionId], references: [id], onDelete: Cascade, map: "Review_attractionId_fkey")
